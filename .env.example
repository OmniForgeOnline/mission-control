# Copy to .env and adjust as needed. (.env is gitignored.)
# All values are optional; shown defaults match the code.

# HTTP port for the harness server.
PORT=4827

# Network interface to bind. 127.0.0.1 = local only; 0.0.0.0 = expose on the LAN.
HARNESS_HOST=127.0.0.1


# Enable (1) or disable (0) scheduled autonomy jobs.
HARNESS_AUTONOMY=1

# Runtime state dir. Defaults to a platform-standard location outside any
# checkout (~/Library/Application Support/mission-control on macOS,
# $XDG_DATA_HOME/mission-control on Linux, %APPDATA%\mission-control on Windows).
# HARNESS_ROOT=

# Connector token store: "keychain" (macOS default), "file" (Linux/Windows),
# or "memory" (testing, lost on restart).
# HARNESS_VAULT=
